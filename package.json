{
  "name": "mj-score-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prepare": "husky install",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seeds": "node scripts/seed-to-supabase.mjs",
    "seed:players": "node scripts/seed-players.mjs",
    "seed:historical:dry": "node scripts/import-historical-games.mjs",
    "seed:historical": "node scripts/import-historical-games.mjs --apply",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "node --test $(find test -maxdepth 1 -name '*.test.js' ! -name '*.e2e.test.js' ! -name '*.integration.test.js') && node -r ts-node/register test/validate-match.cjs",
    "test:integration": "node --test $(find test -maxdepth 1 -name '*.integration.test.js')",
    "test:e2e": "node --test $(find test -maxdepth 1 \\( -name '*.e2e.test.js' -o -name '*.e2e.test.cjs' \\))",
    "test:coverage": "c8 --reporter=text-summary --reporter=lcov --exclude='test/**' npm run test",
    "check:required-files": "bash -c \"if [ ! -f .github/copilot-instructions.md ]; then echo '\".github/copilot-instructions.md\" が存在しません。コミットを中止します。'; exit 1; fi\"",
    "supabase:init": "npx supabase@2.84.2 init",
    "supabase:start": "npx supabase@2.84.2 start",
    "supabase:status": "npx supabase@2.84.2 status",
    "supabase:reset": "npx supabase@2.84.2 db reset",
    "supabase:db:push": "npx supabase@2.84.2 db push --db-url \"$DATABASE_URL\"",
    "check:local-db": "node scripts/check-local-supabase.mjs",
    "dev:local": "npm run check:local-db && next dev",
    "check:local-pages": "node scripts/local-healthcheck.mjs",
    "verify:local": "npm run dev:local & sleep 3; npm run check:local-pages",
    "worklog:start": "node scripts/worklog.mjs start",
    "worklog:review": "node scripts/worklog.mjs review"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@supabase/supabase-js": "^2.100.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "google-auth-library": "^9.14.2",
    "google-spreadsheet": "^4.1.2",
    "lucide-react": "^0.468.0",
    "next": "15.5.14",
    "otplib": "^13.4.0",
    "pg": "^8.20.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "c8": "^10.1.3",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.5.14",
    "husky": "^8.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.19.0 <21",
    "npm": ">=10.8.2 <11"
  },
  "volta": {
    "node": "20.19.0",
    "npm": "10.8.2"
  },
  "packageManager": "npm@10.8.2"
}
