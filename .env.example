# Access control
ACCESS_PASSWORD=your-shared-password

# Environment identifier
# production: 本番環境（ログイン画面がグリーン系バックグラウンド）
# 未設定または production 以外: DEV 環境（ログイン画面がインディゴ/ブルー系 + DEVバッジ）
APP_ENV=production

# Google Spreadsheet settings
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id
GOOGLE_SHEET_TITLE=Sheet1
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# プレイヤーマスタシートの設定
# Google Sheets に「プレイヤーマスタ」シートを作成し、ヘッダー: name 、各行にプレイヤー名を入力することで動的に管理できる
# シートが存在しない場合は lib/players.ts の静的リストを使用する
