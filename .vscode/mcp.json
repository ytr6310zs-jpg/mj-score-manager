{
	"servers": {
		"github": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-github"
			],
			"env": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_TOKEN}"
			}
		},
		"playwright": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@microsoft/mcp-server-playwright"
			]
		},
		"supabasePostgres": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-postgres",
				"${input:supabaseReadonlyDbUrl}"
			]
		}
	},
	"inputs": [
		{
			"id": "supabaseReadonlyDbUrl",
			"type": "promptString",
			"description": "Supabase/Postgres read-only 接続URL (postgres://...)",
			"password": true
		}
	]
}